// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default("")
  userName    String   @map("user_name")
  password    String
  account     String   @unique
  status      Int      @default(1)
  integration Int      @default(0)
  wxId        Int?     @map("wx_id")
  roleId      Int      @default(1) @map("role_id")
  avatar      String?  @default("https://vue.mtruning.club/static/png/person.png") //
  createTime  DateTime @default(now()) @map("create_time")
  updateTime  DateTime @updatedAt @map("update_time")

  @@map("user")
}

model Project {
  id            Int       @id @default(autoincrement())
  createdAt     DateTime  @default(now()) @map("create_time")
  updatedAt     DateTime  @updatedAt @map("update_time")
  userId        Int?      @map("user_id")
  status        Int       @default(1) @db.TinyInt() // 0: 逻辑删除 1: 未删除
  publish       Boolean   @default(false) @map("publish") // 是否发布
  publishTime   DateTime? @map("publish_time") // 发布时间
  unpublishTime DateTime? @map("unpublish_time") // 下架时间
  name          String    @map("name")
  description   String   @map("description")
  previewImage  String?   @map("preview_image")

  @@map("project")
}

model Project_Page {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")
  projectId Int?     @map("project_id")
  pageId    Int?     @map("page_id")

  @@map("project_page")
}

model Page {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")
  name      String   @map("name")
  data      Json     @map("data")

  @@map("page")
}

model Component {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")
  data      Json     @map("data")

  @@map("component")
}
